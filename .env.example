# ─── SmilePro Studio · Variables Docker Compose ─────────────────────────────
# Copia este archivo a .env y rellena los valores:
#   cp .env.example .env
#
# ¡IMPORTANTE! El archivo .env NUNCA debe subirse a git.
# Las claves de APIs van en backend/.env (ya existe en el servidor).
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=smilepro
POSTGRES_PASSWORD=CAMBIA_ESTA_CONTRASEÑA
POSTGRES_DB=smilepro

# ── Frontend ──────────────────────────────────────────────────────────────────
# Puerto en el que se expondrá la web (acceso: http://192.168.1.46:PUERTO)
FRONTEND_PORT=8080

# URL completa del frontend — usada para configurar CORS en el backend.
# En red local: http://192.168.1.46:8080
# Con dominio No-IP:  http://TU_DOMINIO.ddns.net:8080
FRONTEND_URL=http://192.168.1.46:8080
