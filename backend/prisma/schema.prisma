// ─── SmilePro Native Models ──────────────────────────────────────────────────
// Tablas propias de SmilePro (creadas en migrations 001-004).
// Campos en camelCase (Prisma convention) con @map para snake_case en DB.

model Patient {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  firstName    String    @map("first_name")
  lastName     String    @map("last_name")
  dni          String?
  phone        String
  email        String?
  dateOfBirth  DateTime? @map("date_of_birth") @db.Date
  address      String?
  city         String?
  postalCode   String?   @map("postal_code")
  medicalNotes String?   @map("medical_notes")
  allergies    String?
  medications  String?
  bloodType    String?   @map("blood_type")
  active       Boolean   @default(true)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@map("patients")
}

model ClinicalRecord {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  patientId   String   @map("patient_id") @db.Uuid
  userId      String?  @map("user_id") @db.Uuid
  date        DateTime @default(now()) @db.Timestamptz(6)
  type        String   @default("visit")
  title       String   @default("")
  content     String   @default("")
  treatments  Json     @default("[]")
  attachments Json     @default("[]")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@map("clinical_records")
}

model OdontogramEntry {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
