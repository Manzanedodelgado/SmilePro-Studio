    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "UPDATE \"DCitas\" SET \"IdSitC\" = 6, \"MotivoAnulacion\" = 'Cancelada por paciente (WhatsApp: {{ $('Parsear mensaje entrante').item.json.mensaje }})' WHERE \"IdUsu\" = {{ $json.IdUsu }} AND \"IdOrden\" = {{ $json.IdOrden }}",
        "additionalFields": {}
      },
      "id": "sp02-0008",
