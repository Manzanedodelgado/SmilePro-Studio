      "id": "sp02-0001",
      "name": "Webhook · Mensajes Evolution API",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [240, 300],
      "webhookId": "evolution-incoming"
    },
    {
      "parameters": {
        "respondWith": "text",
        "responseBody": "OK"
      },
      "id": "sp02-0002",
      "name": "Responder 200 OK",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [460, 460]
    },
    {
      "parameters": {
        "jsCode": "const body = $input.first().json.body || $input.first().json;\nconst data = body.data || body;\nconst msg = (data.message?.conversation || data.message?.extendedTextMessage?.text || '').trim().toLowerCase();\nconst remitente = data.key?.remoteJid?.replace('@s.whatsapp.net','') || '';\nconst esSi = /^(si|sí|yes|confirmo|confirmar|1)$/i.test(msg);\nconst esNo = /^(no|cancel|cancelar|cancelo|2)$/i.test(msg);\nreturn [{ json: { mensaje: msg, remitente, esSi, esNo, esRespuestaValida: esSi || esNo } }];"
      },
      "id": "sp02-0003",
      "name": "Parsear mensaje entrante",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [460, 300]
    },
    {
      "parameters": {
        "conditions": {
          "conditions": [{ "leftValue": "={{ $json.esRespuestaValida }}", "rightValue": true, "operator": { "type": "boolean", "operation": "equal" } }]
        }
      },
      "id": "sp02-0004",
      "name": "¿Respuesta SÍ o NO?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [680, 300]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT c.\"IdUsu\", c.\"IdOrden\", c.\"Fecha\", c.\"Hora\", p.\"Nombre\"\nFROM \"DCitas\" c\nLEFT JOIN \"Pacientes\" p ON p.\"IdPac\" = c.\"IdPac\"\nWHERE (REPLACE(REPLACE(COALESCE(c.\"Movil\", p.\"TelMovil\"),' ',''),'+','') LIKE '%{{ $json.remitente.slice(-9) }}%')\n  AND c.\"Fecha\" >= {{ (() => { const d=new Date(); return parseInt(d.getFullYear()+String(d.getMonth()+1).padStart(2,'0')+String(d.getDate()).padStart(2,'0')); })() }}\n  AND c.\"IdSitC\" NOT IN (3,4)\nORDER BY c.\"Fecha\" ASC, c.\"Hora\" ASC\nLIMIT 1",
        "additionalFields": {}
      },
      "id": "sp02-0005",
      "name": "BD · Buscar próxima cita del número",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.4,
      "position": [900, 300],
      "credentials": { "postgres": { "id": "1", "name": "SmilePro PostgreSQL" } }
    },
    {
      "parameters": {
        "conditions": {
          "conditions": [{ "leftValue": "={{ $('Parsear mensaje entrante').item.json.esSi }}", "rightValue": true, "operator": { "type": "boolean", "operation": "equal" } }]
        }
      },
      "id": "sp02-0006",
      "name": "¿Es SÍ?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [1120, 300]
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "UPDATE \"DCitas\" SET \"Confirmada\" = 1, \"IdSitC\" = 2 WHERE \"IdUsu\" = {{ $json.IdUsu }} AND \"IdOrden\" = {{ $json.IdOrden }}",
        "additionalFields": {}
      },
      "id": "sp02-0007",
      "name": "BD · Confirmar cita",
