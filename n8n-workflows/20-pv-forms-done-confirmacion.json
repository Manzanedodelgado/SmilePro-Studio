        "jsonBody": "={\n  \"number\": \"{{ $vars.CLINICA_TELEFONO.replace(/[^0-9]/g,'') }}@s.whatsapp.net\",\n  \"text\": \"{{ $json.mensajeInterno }}\"\n}"
      },
