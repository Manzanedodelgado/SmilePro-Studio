{
  "Name": "SmilePro Orthanc",
  "HttpPort": 8042,
  "DicomPort": 4242,
  "AuthenticationEnabled": false,

  "HttpCorsEnabled": true,
  "HttpCorsAllowedOrigins": ["*"],
  "HttpCorsAllowedHeaders": ["*"],
  "HttpCorsAllowedMethods": ["GET", "POST", "PUT", "DELETE", "OPTIONS"],

  "DicomWeb": {
    "Enable": true,
    "Root": "/dicom-web",
    "EnableWado": true,
    "WadoRoot": "/wado",
    "Ssl": false,
    "QidoCaseSensitive": false,
    "HostnameInLinks": false
  },

  "StorageCompression": false,
  "MaximumStorageSize": 0,
  "MaximumPatientCount": 0,
  "LimitFindResults": 0,
  "LimitFindInstances": 0,

  "LogExportedResources": false,
  "KeepAlive": true,
  "TcpNoDelay": true,

  "DefaultEncoding": "Latin1",
  "DeidentifyLogs": false
}
